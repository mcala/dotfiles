{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "cleanupPeriodDays": 10,
    "permissions": {
        "allow": [
            "Read",
            "Bash(python *)",
            "Bash(pytest *)",
            "Bash(ruff check *)",
            "Bash(just --help)",
            "Bash(just install)",
            "Bash(just sync)",
            "Bash(ty check *)",
            "Bash(pyright *)",
            "Bash(ruff format *)",
            "Bash(uv *)",
            "Bash(git log *)",
            "Bash(git diff *)",
            "Bash(git status)",
            "Bash(git branch *)",
            "Bash(ls *)",
            "Bash(cat *)",
            "Bash(find *)",
            "Bash(grep *)",
            "Bash(head *)",
            "Bash(tail *)",
            "Bash(wc *)"
        ],
        "deny": [
            "Read(./.env)",
            "Read(./.env.*)",
            "Read(./secrets/**)",
            "Read(~/.aws/**)",
            "Bash(rm -rf *)",
            "Bash(curl *)",
            "Bash(wget *)"
        ]
    },
    "model": "opus[1m]",
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "WebSearch|WebFetch",
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.claude/scripts/notify.sh search"
                    }
                ]
            }
        ],
        "PermissionRequest": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.claude/scripts/notify.sh approval 'Need approval ⚠️'"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.claude/scripts/notify.sh"
                    }
                ]
            }
        ],
        "Notification": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.claude/scripts/notify.sh approval 'Claude says Hi 👋'"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.claude/scripts/notify.sh finished"
                    }
                ]
            }
        ],
        "SessionEnd": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "npx claude-receipts@latest generate --output html",
                        "timeout": 60
                    }
                ]
            }
        ]
    },
    "statusLine": {
        "type": "command",
        "command": "bash ~/.claude/statusline.sh"
    },
    "enabledPlugins": {
        "pyright-lsp@claude-plugins-official": true,
        "claude-md-management@claude-plugins-official": true
    },
    "sandbox": {
        "enabled": true,
        "autoAllowBashIfSandboxed": true,
        "allowUnsandboxedCommands": false,
        "network": {
            "allowedDomains": [
                "api.github.com",
                " www.njleg.state.nj.us"
            ],
            "allowUnixSockets": [
                "/Users/mcala/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
            ],
            "allowAllUnixSockets": false,
            "allowLocalBinding": true
        },
        "filesystem": {
            "allowWrite": [
                "~/.cache/uv",
                "~/.cache/huggingface",
                "~/.venv/**",
                "~/.local/state/**",
                "~/.claude/memory/**",
                "~/.claude/skills/**"
            ]
        },
        "excludedCommands": [
            "docker",
            "podman"
        ]
    },
    "spinnerVerbs": {
