# Universal SSH config (tag-base). Applies on every host.
# Per-host additions live in ~/.ssh/config.d/*.conf and are pulled in
# below; first-match-wins, so anything they declare overrides these
# generic defaults.

Include ~/.ssh/config.d/*.conf

Host github.com
  HostName ssh.github.com
  Port 443
  User git

Host *
  ControlMaster auto
  ControlPath ~/.ssh/sockets/%r@%h-%p
  ControlPersist 4h
  ForwardAgent yes
  AddKeysToAgent yes
  ConnectTimeout 10
  ServerAliveInterval 60
  ServerAliveCountMax 3
